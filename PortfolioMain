      </div>

      <!-- Copy a card block above to add more projects -->

    </div>
  </main>

  <footer>
    <span>Andreas P · Engineering Portfolio</span> <!-- ★ EDIT: Add last name if you want -->
    <span><a href="mailto:andreaspjobs@gmail.com">andreaspjobs@gmail.com</a></span>
  </footer>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" onclick="closeLightboxOverlay(event)">
    <button class="lightbox-close" onclick="closeLightbox()">×</button>
    <div class="lightbox-inner">
      <div class="lightbox-img">
        <div class="lb-media-strip" id="lb-strip" onscroll="updateLbDots()"></div>
        <div class="lb-dots" id="lb-dots"></div>
      </div>
      <div class="lightbox-content">
        <div class="lb-year" id="lb-year"></div>
        <h2 id="lb-title"></h2>
        <p class="lb-desc" id="lb-desc"></p>
        <div class="lb-tools-label">Tools &amp; Methods</div>
        <div class="lb-tools" id="lb-tools"></div>
        <div class="lb-tags" id="lb-tags"></div>
      </div>
    </div>
  </div>

  <script>
    // ── Dot indicators for card strips ──
    function updateDots(strip) {
      const idx = Math.round(strip.scrollLeft / strip.offsetWidth);
      const dots = strip.closest('.card').querySelectorAll('.media-dots span');
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      strip.querySelectorAll('video').forEach((v, i) => {
        i === idx ? v.play() : v.pause();
      });
    }

    // ── Lightbox ──
    function openLightbox(title, desc, media, year, tools, tags) {
      document.getElementById('lb-title').textContent = title;
      document.getElementById('lb-desc').textContent = desc;
      document.getElementById('lb-year').textContent = year;
      document.getElementById('lb-tools').textContent = tools;
      document.getElementById('lb-tags').innerHTML =
        tags.map(t => `<span class="tag">${t}</span>`).join('');

      const strip = document.getElementById('lb-strip');
      strip.innerHTML = '';
      media.forEach(src => {
        const isVideo = src.match(/\.(mp4|webm|mov)$/i);
        const el = document.createElement(isVideo ? 'video' : 'img');
        el.src = src;
        if (isVideo) { el.muted = true; el.loop = true; el.playsInline = true; }
        strip.appendChild(el);
      });
      strip.scrollLeft = 0;

      const dotsEl = document.getElementById('lb-dots');
      dotsEl.innerHTML = media.map((_, i) =>
        `<span class="${i === 0 ? 'active' : ''}"></span>`).join('');

      const firstVid = strip.querySelector('video');
      if (firstVid) firstVid.play();

      document.getElementById('lightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function updateLbDots() {
      const strip = document.getElementById('lb-strip');
      const idx = Math.round(strip.scrollLeft / strip.offsetWidth);
      document.querySelectorAll('#lb-dots span').forEach((d, i) =>
        d.classList.toggle('active', i === idx));
      strip.querySelectorAll('video').forEach((v, i) => {
        i === idx ? v.play() : v.pause();
      });
    }

    function closeLightbox() {
      document.getElementById('lb-strip').querySelectorAll('video').forEach(v => v.pause());
      document.getElementById('lightbox').classList.remove('open');
      document.body.style.overflow = '';
    }

    function closeLightboxOverlay(e) {
      if (e.target === document.getElementById('lightbox')) closeLightbox();
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

    // ── Filter buttons ──
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        document.querySelectorAll('.card').forEach(card => {
          card.classList.toggle('hidden',
            filter !== 'all' && card.dataset.category !== filter);
        });
      });
    });
  </script>

</body>
</html>
