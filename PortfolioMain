             'Description of this project.',
             ['images/project2a.jpg', 'images/project2b.jpg', 'images/project2.mp4'],
             '2024',
             'Tools used',
             ['Mechanical']
           )">
        <div class="card-img" onscroll="updateDots(this)">
          <img src="images/project2a.jpg" alt="Project 2 photo 1">
