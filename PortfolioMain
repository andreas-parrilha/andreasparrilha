            <span class="tag">Mechanical</span>
          </div>
        </div>
      </div>

      <!-- PROJECT 3 — ★ EDIT or replace -->
      <div class="card"
           data-category="software"
           onclick="openLightbox(
             'Project Title',
             'Description of this project.',
             ['images/project3a.jpg', 'images/project3b.jpg', 'images/project3.mp4'],
             '2024',
             'Tools used',
             ['Software']
           )">
        <div class="card-img" onscroll="updateDots(this)">
          <img src="images/project3a.jpg" alt="Project 3 photo 1">
          <img src="images/project3b.jpg" alt="Project 3 photo 2">
          <video src="images/project3.mp4" muted playsinline loop></video>
        </div>
        <div class="media-dots">
          <span class="active"></span><span></span><span></span>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <div class="card-title">Project Title</div>
            <div class="card-year">2024</div>
          </div>
