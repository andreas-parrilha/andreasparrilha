<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f4f0;
      --surface: #ffffff;
      --text: #1a1a18;
      --muted: #888880;
      --accent: #2a52be;
      --border: #e0dfd9;
      --radius: 4px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      line-height: 1.6;
    }

    /* ── Header ── */
    header {
      padding: 64px 64px 56px;
      border-bottom: 1px solid var(--border);
      opacity: 0;
      animation: fadeUp 0.7s ease forwards;
    }

    .header-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 32px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }

    header h1 {
      font-family: 'DM Mono', monospace;
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 500;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    header h1 span {
      display: block;
      font-size: 0.95rem;
      font-weight: 400;
      letter-spacing: 0.01em;
      color: var(--muted);
      margin-top: 10px;
      font-family: 'DM Sans', sans-serif;
    }

    .contact-links {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
      padding-top: 6px;
    }

    .contact-links a {
      font-family: 'DM Mono', monospace;
      font-size: 0.78rem;
      color: var(--accent);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: opacity 0.2s;
    }

    .contact-links a:hover { opacity: 0.6; }

    .bio {
      max-width: 640px;
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.75;
    }

    .skills-row {
      margin-top: 28px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .skills-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-right: 4px;
    }

    .skill-chip {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 99px;
      color: var(--text);
      background: var(--surface);
    }

    /* ── Main ── */
    main {
      padding: 64px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.15s forwards;
    }

    .filter-btn {
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      padding: 6px 14px;
      border: 1px solid var(--border);
      border-radius: 99px;
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-btn:hover,
    .filter-btn.active {
      background: var(--text);
      color: var(--bg);
      border-color: var(--text);
    }

    /* ── Grid ── */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 2px;
    }

    /* ── Card ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      overflow: hidden;
      cursor: pointer;
      transition: box-shadow 0.25s ease;
      opacity: 0;
      animation: fadeUp 0.6s ease forwards;
    }

    .card.hidden { display: none; }
    .card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); }

    /* ── Card media strip ── */
    .card-img {
      width: 100%;
      aspect-ratio: 4/3;
      overflow-x: auto;
      overflow-y: hidden;
      background: var(--bg);
      display: flex;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .card-img::-webkit-scrollbar { display: none; }

    .card-img img,
    .card-img video {
      flex: 0 0 100%;
      width: 100%;
      height: 100%;
      object-fit: cover;
      scroll-snap-align: start;
      display: block;
    }

    /* Dot indicators */
    .media-dots {
      display: flex;
      justify-content: center;
      gap: 5px;
      padding: 7px 0 0;
      background: var(--surface);
    }

    .media-dots span {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--border);
      display: block;
      transition: background 0.2s;
    }

    .media-dots span.active { background: var(--accent); }

    .card-body {
      padding: 22px 26px 26px;
      border-top: 1px solid var(--border);
    }

    .card-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .card-title {
      font-family: 'DM Mono', monospace;
      font-size: 0.95rem;
      font-weight: 500;
    }

    .card-year {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
    }

    .card-desc {
      font-size: 0.87rem;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 14px;
    }

    .card-tags { display: flex; flex-wrap: wrap; gap: 6px; }

    .tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 2px 7px;
      border-radius: var(--radius);
    }

    /* ── Lightbox ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(20,20,18,0.92);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 32px;
      backdrop-filter: blur(4px);
    }

    .lightbox.open { display: flex; }

    .lightbox-inner {
      background: var(--surface);
      max-width: 960px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      border-radius: var(--radius);
      display: grid;
      grid-template-columns: 1.1fr 1fr;
    }

    /* ── Lightbox media strip ── */
    .lightbox-img {
      background: var(--bg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .lb-media-strip {
      flex: 1;
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .lb-media-strip::-webkit-scrollbar { display: none; }

    .lb-media-strip img,
    .lb-media-strip video {
      flex: 0 0 100%;
      width: 100%;
      height: 100%;
      object-fit: cover;
      scroll-snap-align: start;
      display: block;
    }

    .lb-dots {
      display: flex;
      justify-content: center;
      gap: 5px;
      padding: 8px 0;
      background: var(--bg);
    }

    .lb-dots span {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--muted);
      opacity: 0.4;
      display: block;
      transition: opacity 0.2s;
    }

    .lb-dots span.active { opacity: 1; background: var(--accent); }

    .lightbox-content {
      padding: 48px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 14px;
    }

    .lightbox-content h2 {
      font-family: 'DM Mono', monospace;
      font-size: 1.3rem;
      font-weight: 500;
      line-height: 1.2;
    }

    .lb-year {
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      color: var(--muted);
    }

    .lb-desc {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.8;
    }

    .lb-tools-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 4px;
    }

    .lb-tools {
      font-family: 'DM Mono', monospace;
      font-size: 0.82rem;
      color: var(--text);
    }

    .lb-tags { display: flex; flex-wrap: wrap; gap: 6px; }

    .lightbox-close {
      position: absolute;
      top: 24px;
      right: 32px;
      background: none;
      border: none;
      color: #fff;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 28px 64px;
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      color: var(--muted);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }

    footer a { color: var(--accent); text-decoration: none; }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card:nth-child(1) { animation-delay: 0.15s; }
    .card:nth-child(2) { animation-delay: 0.25s; }
    .card:nth-child(3) { animation-delay: 0.35s; }
    .card:nth-child(4) { animation-delay: 0.45s; }
    .card:nth-child(5) { animation-delay: 0.55s; }
    .card:nth-child(6) { animation-delay: 0.65s; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      header, main, footer { padding: 32px 24px; }
      .header-top { flex-direction: column; }
      .contact-links { align-items: flex-start; }
      .lightbox-inner { grid-template-columns: 1fr; }
      .lightbox-img { aspect-ratio: 4/3; max-height: 260px; }
      .lightbox-content { padding: 28px 24px; }
    }
  </style>
</head>
<body>

  <header>
    <div class="header-top">
      <h1>
        Andreas P <!-- ★ EDIT: Add last name if you want -->
        <span>Aerospace Engineer · University of Texas at Austin · Class of 2027</span>
      </h1>
      <div class="contact-links">
        <a href="mailto:andreaspjobs@gmail.com">andreaspjobs@gmail.com</a>
        <a href="https://linkedin.com/in/yourhandle" target="_blank">linkedin.com/in/yourhandle</a> <!-- ★ EDIT -->
        <a href="https://github.com/yourhandle" target="_blank">github.com/yourhandle</a> <!-- ★ EDIT -->
      </div>
    </div>

    <p class="bio">
      Engineering student with a focus on rocketry but interested in branching out to other fields.
      Excited to work on improving both atmospheric and space flight in any way I can.
