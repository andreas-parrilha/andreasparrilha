           )">
        <div class="card-img" onscroll="updateDots(this)">
          <!-- ★ EDIT: Replace filenames with your actual image/video files -->
          <img src="images/ViperOR.png" alt="Viper Open Rocket Design">
          <img src="images/MeNViper.jpg" alt="Me holding The Viper">
          <video src="images/Viper3.mov" muted playsinline loop></video>
        </div>
        <div class="media-dots">
          <span class="active"></span><span></span><span></span>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <div class="card-title">Viper</div>
            <div class="card-year">2025</div>
          </div>
          <div class="card-desc">A scratch designed and built L1 certification rocket.</div>
